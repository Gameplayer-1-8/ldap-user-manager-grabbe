# LDAP Server Configuration
LDAP_URI="ldap://your-ldap-server:389"

# Admin Bind Account (The management user)
LDAP_ADMIN_DN="cn=admin,dc=example,dc=com"
LDAP_ADMIN_PASSWORD="your_admin_password"

# Base DNs for Searches
LDAP_BASE_DN="dc=example,dc=com"
LDAP_USERS_OU="ou=users,dc=example,dc=com"
LDAP_GROUPS_OU="ou=groups,dc=example,dc=com"

# Auth Security
# Use a long random string for JWT signing
JWT_SECRET="your_jwt_secret_change_me"
